{
  "name": "joplin-plugin-code-beautifier",
  "version": "1.0.0",
  "description": "Beautiful code blocks with 6 hand-crafted themes for Joplin",
  "main": "dist/index.js",
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "dist": "npm run build && mkdir -p publish && cd dist && tar -cf ../publish/joplin-plugin-code-beautifier.jpl * && cd .. && cp package.json publish/"
  },
  "keywords": [
    "joplin-plugin",
    "code",
    "theme",
    "beautify",
    "syntax-highlighting"
  ],
  "author": "heria",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heria/joplin-plugin-code-beautifier"
  },
  "homepage": "https://github.com/heria/joplin-plugin-code-beautifier#readme",
  "files": [
    "dist/",
    "publish/",
    "src/"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1"
  }
}
